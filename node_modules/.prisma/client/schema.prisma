generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String?
  name      String?
  projects  Project[]
  createdAt DateTime  @default(now())
}

model Project {
  id            String         @id @default(cuid())
  name          String
  config        Json
  userId        String
  user          User           @relation(fields: [userId], references: [id])
  history       History[]
  generatedApps GeneratedApp[]
  dynamicData   DynamicData[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model History {
  id        String   @id @default(cuid())
  config    Json
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  createdAt DateTime @default(now())
}

model GeneratedApp {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id])
  deploymentUrl String?
  status        String   @default("active")
  createdAt     DateTime @default(now())
}

model DynamicData {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  modelName String
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, modelName])
}
