{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@genforge/shared": ["../../packages/shared/src"],
      "@genforge/api-generator": ["../../packages/api-generator/src"],
      "@genforge/db-generator": ["../../packages/db-generator/src"],
      "@genforge/runtime-engine": ["../../packages/runtime-engine/src"],
      "@genforge/ui-engine": ["../../packages/ui-engine/src"]
    }
  },
  "include": ["src/**/*"]
}
